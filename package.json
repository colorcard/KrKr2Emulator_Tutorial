{
  "name": "krkr2-tutorial-docs",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "docs:prepare": "python scripts/prepare_mkdocs.py",
    "docs:dev": "npm run docs:prepare && vitepress dev .mkdocs-src",
    "docs:build": "npm run docs:prepare && node --max-old-space-size=8192 ./node_modules/vitepress/bin/vitepress.js build .mkdocs-src",
    "docs:preview": "vitepress preview .mkdocs-src"
  },
  "devDependencies": {
    "vitepress": "1.6.4"
  }
}
